video/node_modules/
video/out/
video/dist/
video/.remotion/

# Node.js 依賴（根目錄）
node_modules/

# Python 快取（全域）
__pycache__/
*.pyc

# 臨時檔案
temp/

# 大型二進位檔案（不適合 git 追蹤）
*.m4a
*.mp3
*.mp4
*.wav
*.mov
*.zip
*.tar.gz
*.rar
*.pdf

