#!/usr/bin/env bash
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TeacherOS — Git Pre-commit Hook（身份驗證 + 路徑攔截）
# 路徑：setup/hooks/pre-commit
# 安裝方式：執行 bash setup/install-hooks.sh
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# 作用：在 git commit 的瞬間，確認：
#   1. 當前使用者有登記在 ai-core/acl.yaml 中
#   2. 準備提交的檔案都在該使用者的 allowed_paths 範圍內
#   3. 任何 protected_always 的核心路徑修改都會被攔截
#
# 緊急繞過（不建議）：git commit --no-verify
#   注意：此操作不會繞過 GitHub CODEOWNERS 審核，David 仍會在 PR 中看到所有變更。

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
ENV_FILE="$REPO_ROOT/setup/environment.env"
ACL_FILE="$REPO_ROOT/ai-core/acl.yaml"

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  TeacherOS Pre-commit 身份與權限檢查"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ── Step 1：雙重讀取身份 ────────────────────────────────

ENV_EMAIL=""
if [ -f "$ENV_FILE" ]; then
    ENV_EMAIL=$(grep -E "^USER_EMAIL=" "$ENV_FILE" | cut -d'=' -f2 | tr -d '[:space:]')
fi

GIT_EMAIL=$(git config user.email 2>/dev/null || echo "")

# 以 environment.env 為主，git config 為備
CURRENT_EMAIL="${ENV_EMAIL:-$GIT_EMAIL}"

if [ -z "$CURRENT_EMAIL" ]; then
    echo -e "${RED}[錯誤] 無法識別使用者身份。${NC}"
    echo "請確認 setup/environment.env 中的 USER_EMAIL 欄位已填入。"
    echo ""
    exit 1
fi

# 若兩者都有值但不一致，顯示警告
if [ -n "$ENV_EMAIL" ] && [ -n "$GIT_EMAIL" ] && [ "$ENV_EMAIL" != "$GIT_EMAIL" ]; then
    echo -e "${YELLOW}[警告] 身份資訊不一致，以 environment.env 為準：${NC}"
    echo "  environment.env  USER_EMAIL : $ENV_EMAIL"
    echo "  git config user.email       : $GIT_EMAIL"
    echo ""
fi

echo "  識別身份：$CURRENT_EMAIL"

# ── Step 2：確認 ACL 與暫存檔案 ────────────────────────

if [ ! -f "$ACL_FILE" ]; then
    echo -e "${YELLOW}[警告] 找不到 ai-core/acl.yaml，跳過權限檢查。${NC}"
    echo "請聯絡 David 確認系統設定。"
    echo ""
    exit 0
fi

STAGED_FILES=$(git diff --cached --name-only 2>/dev/null)

if [ -z "$STAGED_FILES" ]; then
    echo "  暫存區為空，無需檢查。"
    echo ""
    exit 0
fi

# ── Step 3：Python 解析 ACL 並比對路徑 ─────────────────

PYTHON_CMD=$(which python3 2>/dev/null || which python 2>/dev/null)

if [ -z "$PYTHON_CMD" ]; then
    echo -e "${YELLOW}[警告] 找不到 Python 3，跳過 ACL 路徑檢查。${NC}"
    echo "建議安裝 Python 3（brew install python3）以啟用完整保護。"
    echo ""
    exit 0
fi

RESULT=$($PYTHON_CMD << PYTHON_SCRIPT
import sys, os, re

repo_root = """$REPO_ROOT"""
current_email = """$CURRENT_EMAIL"""
staged_raw = """$STAGED_FILES"""
staged_files = [f.strip() for f in staged_raw.strip().split('\n') if f.strip()]
acl_path = os.path.join(repo_root, 'ai-core', 'acl.yaml')

def parse_acl(path):
    with open(path, 'r', encoding='utf-8') as f:
        content = f.read()

    teachers = {}

    # 解析 admin 區塊
    admin_m = re.search(r'admin:\s*\n(.*?)(?=\n\S|\Z)', content, re.DOTALL)
    if admin_m:
        admin_block = admin_m.group(0)
        for email in re.findall(r'email:\s*([^\s#\n]+)', admin_block):
            teachers[email.strip()] = {'is_admin': True, 'allowed_paths': ['*'], 'name': 'Admin'}

    # 解析 teachers 清單（逐個 - name: 區塊）
    for m in re.finditer(
        r'-\s+name:\s+(.+?)\n(?:.*?\n)*?\s+email:\s+([^\s#\n]+)(?:.*?\n)*?\s+allowed_paths:\s*\n((?:\s+-[^\n]+\n)*)',
        content, re.DOTALL
    ):
        name = m.group(1).strip()
        email = m.group(2).strip()
        paths_raw = m.group(3)
        paths = [p.strip().strip('"\'') for p in re.findall(r'-\s+([^\n#]+)', paths_raw)]
        if email not in teachers:
            teachers[email] = {'is_admin': False, 'allowed_paths': paths, 'name': name}

    # 解析 protected_always
    protected = []
    pa_m = re.search(r'protected_always:\s*\n((?:\s+-[^\n]+\n)*)', content)
    if pa_m:
        protected = [p.strip().strip('"\'') for p in re.findall(r'-\s+([^\n#]+)', pa_m.group(1))]

    return teachers, protected

def matches(file_path, pattern):
    if pattern == '*':
        return True
    if pattern.endswith('/'):
        return file_path.startswith(pattern)
    import fnmatch
    if '*' in pattern:
        return fnmatch.fnmatch(file_path, pattern)
    return file_path == pattern or file_path.startswith(pattern.rstrip('/') + '/')

try:
    teachers, protected = parse_acl(acl_path)

    if current_email not in teachers:
        print(f"UNKNOWN_USER:{current_email}")
        sys.exit(0)

    user = teachers[current_email]

    if user['is_admin']:
        print("ADMIN_OK")
        sys.exit(0)

    blocked = []
    for f in staged_files:
        is_protected = any(matches(f, p) for p in protected)
        is_allowed = any(matches(f, p) for p in user['allowed_paths'])
        if is_protected:
            blocked.append(f"PROTECTED:{f}")
        elif not is_allowed:
            blocked.append(f"BLOCKED:{f}")

    if blocked:
        for b in blocked:
            print(b)
    else:
        print(f"TEACHER_OK:{user['name']}")

except Exception as e:
    print(f"ERROR:{e}")
PYTHON_SCRIPT
)

# ── Step 4：解析結果 ────────────────────────────────────

if echo "$RESULT" | grep -q "^ADMIN_OK"; then
    echo -e "  ${GREEN}管理員身份確認，全域授權通過。${NC}"
    echo ""
    exit 0
fi

if echo "$RESULT" | grep -q "^UNKNOWN_USER:"; then
    UNKNOWN=$(echo "$RESULT" | grep "^UNKNOWN_USER:" | cut -d: -f2)
    echo -e "${RED}[拒絕] 此帳號未登記於 acl.yaml：${NC} $UNKNOWN"
    echo "請聯絡 David，請他將你加入 ai-core/acl.yaml 後再操作。"
    echo ""
    exit 1
fi

if echo "$RESULT" | grep -q "^ERROR:"; then
    ERR=$(echo "$RESULT" | grep "^ERROR:" | cut -d: -f2-)
    echo -e "${YELLOW}[警告] ACL 檢查時發生錯誤，跳過路徑比對：${NC} $ERR"
    echo "請聯絡 David 確認 ai-core/acl.yaml 格式正確。"
    echo ""
    exit 0
fi

if echo "$RESULT" | grep -q "^TEACHER_OK:"; then
    NAME=$(echo "$RESULT" | grep "^TEACHER_OK:" | cut -d: -f2)
    echo -e "  ${GREEN}身份確認：${NAME}，所有修改在授權範圍內，通過。${NC}"
    echo ""
    exit 0
fi

# 有被攔截的檔案
echo ""
echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${RED}  [拒絕提交] 發現超出授權的檔案修改${NC}"
echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

while IFS= read -r line; do
    if echo "$line" | grep -q "^BLOCKED:"; then
        FILE=$(echo "$line" | cut -d: -f2-)
        echo -e "  ${RED}✗ 無操作權限：${NC} $FILE"
    elif echo "$line" | grep -q "^PROTECTED:"; then
        FILE=$(echo "$line" | cut -d: -f2-)
        echo -e "  ${RED}✗ 受保護的核心路徑：${NC} $FILE"
    fi
done <<< "$RESULT"

echo ""
echo "你的授權範圍請查閱：ai-core/acl.yaml"
echo "如需擴充權限，請聯絡 David 更新 acl.yaml（需要 GitHub PR 審核）。"
echo ""
echo "如確認為緊急必要操作，可使用："
echo "  git commit --no-verify"
echo "此操作仍會觸發 GitHub PR 的 CODEOWNERS 審核，David 將看到所有變更。"
echo ""
exit 1
