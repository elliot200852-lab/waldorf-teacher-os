#!/usr/bin/env bash
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TeacherOS — Post-merge Hook（Good-notes 新分享通知）
# 路徑：setup/hooks/post-merge
# 觸發時機：git pull / git merge 完成後自動執行
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# 功能：檢查剛拉進來的 commit 是否有人在 Good-notes/ 新增或修改筆記，
#       若有，在終端機顯示通知，包含作者姓名與檔案清單。
#       自己的改動不通知。

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"

# ── 取得自己的 Email（排除自己的 commit）──────────────────
MY_EMAILS=""
ENV_FILE="$REPO_ROOT/setup/environment.env"
if [ -f "$ENV_FILE" ]; then
    env_email=$(grep -E "^USER_EMAIL=" "$ENV_FILE" 2>/dev/null | cut -d'=' -f2 | tr -d '[:space:]')
    [ -n "$env_email" ] && MY_EMAILS="$env_email"
fi
git_email=$(git config user.email 2>/dev/null || echo "")
[ -n "$git_email" ] && MY_EMAILS="$MY_EMAILS $git_email"

# ── 檢查 ORIG_HEAD 是否存在 ──────────────────────────────
if [ ! -f "$REPO_ROOT/.git/ORIG_HEAD" ]; then
    exit 0
fi

ORIG_HEAD=$(cat "$REPO_ROOT/.git/ORIG_HEAD")

# ── 快速檢查：有沒有 Good-notes/ 的變動 ──────────────────
HAS_CHANGES=$(git diff --name-only "$ORIG_HEAD..HEAD" -- "Good-notes/" 2>/dev/null)

if [ -z "$HAS_CHANGES" ]; then
    exit 0
fi

# ── 用 Python 解析並輸出通知 ──────────────────────────────
python3 - "$REPO_ROOT" "$MY_EMAILS" "$ORIG_HEAD" <<'PYTHON_SCRIPT'
import sys, os, re, subprocess

repo_root = sys.argv[1]
my_emails = set(sys.argv[2].split())
orig_head = sys.argv[3]

# ── 從 acl.yaml 建立 email/github_username → 中文姓名對照 ──
name_map = {}
acl_path = os.path.join(repo_root, "ai-core", "acl.yaml")
if os.path.exists(acl_path):
    with open(acl_path, encoding="utf-8") as f:
        acl = f.read()
    # 找所有 name/email/github_username 組合
    current_name = ""
    current_github = ""
    for line in acl.splitlines():
        m_name = re.match(r'\s+-\s+name:\s*(.+)', line)
        if m_name:
            raw = m_name.group(1).strip().strip('"\'')
            # 取括號前的中文名，如「林信宏（David）」→「林信宏」
            current_name = re.sub(r'[（(].+[）)]', '', raw).strip()
            current_github = ""
        m_email = re.match(r'\s+email:\s*(.+)', line)
        if m_email and current_name:
            email = m_email.group(1).strip().strip('"\'')
            name_map[email] = current_name
        m_gh = re.match(r'\s+github_username:\s*(.+)', line)
        if m_gh and current_name:
            gh = m_gh.group(1).strip().strip('"\'')
            name_map[f"{gh}@users.noreply.github.com"] = current_name
            current_github = gh

def resolve(email, git_name):
    return name_map.get(email, git_name)

# ── 在 Python 內呼叫 git log ──
result = subprocess.run(
    ["git", "-c", "core.quotePath=false", "log", f"{orig_head}..HEAD",
     "--diff-filter=ACMR", "--name-status", "--format=%H %ae %an",
     "--", "Good-notes/"],
    capture_output=True, text=True, cwd=repo_root
)
changes_text = result.stdout
entries = []  # [(display_name, symbol, filename)]
current_email = ""
current_name = ""

for line in changes_text.splitlines():
    if not line.strip():
        continue
    # commit 行：HASH email name
    if re.match(r'^[0-9a-f]{40} ', line):
        parts = line.split(' ', 2)
        current_email = parts[1]
        git_author = parts[2] if len(parts) > 2 else ""
        current_name = resolve(current_email, git_author)
        continue
    # 跳過自己
    if current_email in my_emails:
        continue
    # 檔案行：STATUS\tPATH
    cols = line.split('\t')
    if len(cols) < 2:
        continue
    st, fpath = cols[0], cols[1]
    sym = {"A": "+", "C": "+", "M": "~", "R": ">"}.get(st, "?")
    fname = os.path.basename(fpath)
    entries.append((current_name, sym, fname))

# 去重
entries = list(dict.fromkeys(entries))

if not entries:
    sys.exit(0)

# ── 輸出通知 ──
print()
print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
print("  Good-notes 有新分享！")
print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
print()

# 按作者分組
from collections import OrderedDict
by_author = OrderedDict()
for name, sym, fname in entries:
    by_author.setdefault(name, []).append((sym, fname))

for author, files in by_author.items():
    print(f"  {author} 分享了 {len(files)} 個筆記：")
    for sym, fname in files:
        print(f"    {sym} {fname}")
    print()

print("  查看詳情：git log ORIG_HEAD..HEAD -- Good-notes/")
print()
print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
print()
PYTHON_SCRIPT
